+
+  test("returns undefined when no cache or promptOrder provided", () => {
+    expect(ProviderConfig.fromUserProviderConfig({})).toBeUndefined()
+  })
+
+  test("converts cache config correctly", () => {
+    const input = {
+      cache: {
+        enabled: false,
+        ttl: "1h" as const,
